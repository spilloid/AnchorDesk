# Copy this to secrets.env and fill in real values.
# secrets.env is gitignored — never commit it.
#
# Apply with:  make secrets

# Postgres credentials
POSTGRES_USER=stadmin
POSTGRES_PASSWORD=changeme-user

# Prisma / backend connection string (must match user/pass/host above)
# Host is "db" — the StatefulSet headless service name
DATABASE_URL=postgresql://stadmin:changeme-user@db:5432/anchordesk

# Auth (1.1.0) — local accounts + OIDC + SAML all run side by side.
# APP_BASE_URL is the public URL (used to build OIDC/SAML callbacks).
# AUTH_SESSION_SECRET signs session cookies — generate: openssl rand -hex 32
APP_BASE_URL=https://rmm.spillerstech.us
AUTH_SESSION_SECRET=changeme-generate-32-bytes-hex

# Bootstrap admin — creates the first local admin if the users table is empty.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme-strong-admin-password

# OIDC — set OIDC_DISABLED=true in the deployment to skip auth during dev.
# When ready for real auth, fill these and flip OIDC_DISABLED to false.
#
# Authentik example (auth.spillerstech.us):
#   OIDC_ISSUER_URL=https://auth.spillerstech.us/application/o/anchordesk/
#
OIDC_ISSUER_URL=https://auth.spillerstech.us/application/o/anchordesk/
OIDC_CLIENT_ID=anchordesk
OIDC_CLIENT_SECRET=changeme-oidc-secret

# SAML 2.0 (optional) — IdP SSO URL + base64 signing cert (PEM body).
SAML_ENTRY_POINT=
SAML_IDP_CERT=

# ConnectWise Manage (optional — leave blank if not using CW sync)
CWM_SERVER=
CWM_COMPANY=
CWM_PUBKEY=
CWM_PRIVATEKEY=
CWM_CLIENTID=

# Attachment storage secret (only needed for S3-compatible storage).
S3_SECRET_ACCESS_KEY=

# SMTP_PASS and TRMM_API_KEY are intentionally not kept in this plaintext
# template. They live in integrations.sops.env and are applied by `make secrets`.
